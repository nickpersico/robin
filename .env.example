# Flask
SECRET_KEY=change-me-to-a-long-random-string
FLASK_ENV=development

# Postgres
DATABASE_URL=postgresql://localhost/robin

# Close OAuth App credentials
# Create an OAuth App at: https://app.close.com/settings/developer/
CLOSE_CLIENT_ID=your_close_client_id
CLOSE_CLIENT_SECRET=your_close_client_secret

# Must match the Redirect URI registered in your Close OAuth App
CLOSE_REDIRECT_URI=http://localhost:5000/auth/callback
